<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Happy Sweet Sixteen Avyyy 💖</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      height: 100vh;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: #ffd6e8; /* light pink */
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      user-select: none;
    }

    .screen {
      position: absolute;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 20px;
    }
    .screen.active { display: flex; }

    /* Envelope */
    .envelope {
      width: 220px;
      height: 140px;
      background: #c1121f; /* red */
      position: relative;
      border-radius: 6px;
      cursor: pointer;
      box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }
    .envelope::before {
      content: '';
      position: absolute;
      inset: 0;
      clip-path: polygon(0 0, 50% 55%, 100% 0, 100% 100%, 0 100%);
      background: #e63946;
    }

    /* Letter */
    .letter {
      width: 280px;
      padding: 30px 20px;
      background: #ffb7d5;
      border-radius: 12px;
      box-shadow: 0 15px 30px rgba(0,0,0,0.25);
      cursor: pointer;
      background-image: radial-gradient(rgba(255,255,255,0.6) 2px, transparent 2px),
                        radial-gradient(rgba(255,255,255,0.6) 2px, transparent 2px);
      background-size: 24px 24px;
      background-position: 0 0, 12px 12px;
    }

    /* Notification */
    .notification {
      background: #f5e6cc; /* beige */
      color: #333;
      padding: 18px 22px;
      border-radius: 14px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.25);
      font-size: 1.1rem;
      cursor: pointer;
    }
    .heart { color: #c1121f; }

    /* Message */
    .big-message {
      max-width: 600px;
      background: rgba(255,255,255,0.85);
      padding: 28px;
      border-radius: 18px;
      font-size: 1.1rem;
      line-height: 1.7;
      cursor: pointer;
    }

    /* Countdown */
    .countdown {
      font-size: 5rem;
      font-weight: 700;
      color: #c1121f;
    }

    /* Cake */
    .cake {
      width: 200px;
      height: 160px;
      position: relative;
      cursor: pointer;
    }
    .tier {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      background: #ffcad4;
      border-radius: 10px;
      box-shadow: inset 0 -8px rgba(0,0,0,0.08);
    }
    .tier.one { width: 200px; height: 60px; bottom: 0; }
    .tier.two { width: 150px; height: 50px; bottom: 55px; }
    .tier.three { width: 100px; height: 40px; bottom: 100px; }
    .candle {
      position: absolute;
      width: 10px;
      height: 30px;
      background: #fff;
      left: 50%;
      top: -30px;
      transform: translateX(-50%);
    }
    .flame {
      position: absolute;
      width: 14px;
      height: 14px;
      background: orange;
      border-radius: 50% 50% 50% 50%;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      animation: flicker 0.8s infinite;
    }
    @keyframes flicker {
      0% { transform: translateX(-50%) scale(1); }
      50% { transform: translateX(-50%) scale(0.85); }
      100% { transform: translateX(-50%) scale(1); }
    }

    /* Final text */
    .final-text {
      font-size: 2.6rem;
      font-weight: 800;
      color: #c1121f;
      text-align: center;
    }

    /* Hearts confetti */
    .heart-fall {
      position: fixed;
      top: -10px;
      font-size: 20px;
      animation: fall linear forwards;
    }
    @keyframes fall {
      to { transform: translateY(110vh); }
    }
  </style>
</head>
<body>

  <!-- Screen 1: Envelope -->
  <div class="screen active" id="s1">
    <div class="envelope" onclick="next()"></div>
  </div>

  <!-- Screen 2: Letter -->
  <div class="screen" id="s2">
    <div class="letter" onclick="next()">
      <h2>💌 Happy Birthday Avyyy 💌</h2>
      <p>(touch again)</p>
    </div>
  </div>

  <!-- Screen 3: Notification -->
  <div class="screen" id="s3">
    <div class="notification" onclick="next()">
      New message <span class="heart">❤️</span>
    </div>
  </div>

  <!-- Screen 4: Big Message -->
  <div class="screen" id="s4">
    <div class="big-message" onclick="next()">
      Avyyy, today isn’t just your birthday — it’s a celebration of your smile,
      your kindness, and the beautiful light you bring into every space you enter.
      Sixteen is the beginning of so many dreams, adventures, and wonderful memories.
      May this year wrap you in happiness, confidence, and love. Never stop being
      exactly who you are, because you are truly special. 💖✨
      <br><br>(touch the screen)
    </div>
  </div>

  <!-- Screen 5: Countdown -->
  <div class="screen" id="s5">
    <div class="countdown" id="count">10</div>
  </div>

  <!-- Screen 6: Cake -->
  <div class="screen" id="s6">
    <div>
      <div class="cake" onclick="blow()">
        <div class="tier one"></div>
        <div class="tier two"></div>
        <div class="tier three"></div>
        <div class="candle"><div class="flame" id="flame"></div></div>
      </div>
      <p>Make a wish & blow the candle ✨</p>
    </div>
  </div>

  <!-- Screen 7: Final -->
  <div class="screen" id="s7">
    <div class="final-text" onclick="endShow()">
      🎉 HAPPY SWEET SIXTEEN AVYYY 🎉
    </div>
  </div>

<script>
  let step = 1;
  function next() {
    document.getElementById('s' + step).classList.remove('active');
    step++;
    document.getElementById('s' + step).classList.add('active');
    if (step === 5) startCountdown();
  }

  function startCountdown() {
    let n = 10;
    const el = document.getElementById('count');
    const i = setInterval(() => {
      n--;
      el.textContent = n;
      if (n === 0) {
        clearInterval(i);
        next();
      }
    }, 700);
  }

  function blow() {
    document.getElementById('flame').style.display = 'none';
    next();
    hearts();
  }

  function hearts() {
    for (let i = 0; i < 60; i++) {
      const h = document.createElement('div');
      h.className = 'heart-fall';
      h.textContent = '💖';
      h.style.left = Math.random() * 100 + 'vw';
      h.style.animationDuration = (Math.random() * 3 + 2) + 's';
      document.body.appendChild(h);
      setTimeout(() => h.remove(), 5000);
    }
  }

  function endShow() {
    document.body.innerHTML = '<h2 style="color:#c1121f">💗 The End 💗</h2>';
  }
</script>

</body>
  </html>
